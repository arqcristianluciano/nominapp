VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
# VAPID public key para Web Push (la privada va en Supabase Edge Function secrets)
VITE_PUSH_VAPID_PUBLIC_KEY=
# DSN público de Sentry para observabilidad de errores de cliente.
# Tomar de sentry.io/settings/.../keys/
VITE_SENTRY_DSN=
# Opcionales para subir source maps a Sentry en build (no van al cliente).
# Configurar en CI/Vercel; sin ellos vite-plugin queda inactivo.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

