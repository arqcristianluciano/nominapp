VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
# VAPID public key para Web Push (la privada va en Supabase Edge Function secrets)
VITE_PUSH_VAPID_PUBLIC_KEY=
# DSN público de Sentry para observabilidad de errores de cliente.
# Tomar de sentry.io/settings/.../keys/
VITE_SENTRY_DSN=
# Release identifier de Sentry (ej: commit SHA o tag). Se setea en CI.
VITE_SENTRY_RELEASE=
# Acceso rápido de prueba en el login (botones "entrar como <rol>").
# SOLO ponlo en 'true' en entornos de prueba: en producción real déjalo vacío
# para que nadie pueda entrar como cualquier rol desde la URL.
VITE_ENABLE_TEST_LOGIN=
